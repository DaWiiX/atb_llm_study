# Copy this file to `.env` (kept out of git) and edit the values to match
# your machine. The package auto-loads `.env` from the current working
# directory or any parent (up to 4 levels).

# Local Qwen3-VL-Embedding-2B checkpoint directory.
# Used by every test/benchmark under atb_python_qwen3vl_embedding/tests/.
QWEN3VL_EMB_MODEL_DIR=/path/to/Qwen3-VL-Embedding-2B
