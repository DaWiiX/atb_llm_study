# Copy this file to `.env` (kept out of git) and edit the values to match
# your machine. The Python package auto-loads `.env` from the current working
# directory or any parent (up to 4 levels); `atb_cpp_llm/build_and_test.sh`
# explicitly sources it; all generator / diagnostic / test scripts read these
# values via `os.environ` (no hard-coded paths).

# ── Required ────────────────────────────────────────────────────────
# Local Qwen3-VL-Embedding-2B checkpoint directory (must contain
# `config.json`, `preprocessor_config.json`, `model.safetensors`).
QWEN3VL_EMB_MODEL_DIR=/path/to/Qwen3-VL-Embedding-2B

# ── Optional ────────────────────────────────────────────────────────
# Path to a checked-out copy of the Qwen3-VL-Embedding reference repo (the
# `src/` directory containing the Python implementation we cross-check
# against). Only the Python package needs this; C++ does not.
QWEN3VL_EMB_SRC=/path/to/Qwen3-VL-Embedding/src

# Path to a checked-out copy of huggingface/transformers (the `src/` dir).
# Used only by tests/diagnostics that import Qwen3VL via the reference
# transformers implementation (compare_with_torch.py, compare_multimodal.py).
QWEN3VL_EMB_TRANSFORMERS_SRC=/path/to/transformers/src
